{
	"printWidth": 120,
	"singleQuote": true,
	"trailingComma": "es5",
	"useTabs": true,
	"tabWidth": 2,
	"endOfLine": "lf",
	"semi": true,
	"bracketSpacing": true,
	"quoteProps": "consistent",
	"arrowParens": "always",
	"plugins": ["@ianvs/prettier-plugin-sort-imports"],
	"importOrder": ["^@core/(.*)$", "^@server/(.*)$", "^@ui/(.*)$", "^[./]"],
	"importOrderTypeScriptVersion": "5.0.0",
	"importOrderCaseSensitive": false
}
